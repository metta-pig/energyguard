# Example environment variables (copy to `.env` locally)

# Active theme id — must match a registered theme in src/lib/applyTheme.ts
# (see src/lib/themePresets.ts for descriptions and prompt hints).
#
# Personality presets (pick one so each spin-off feels different):
#   modern | classic | sports | retro | shop | info | showcase
# System / reference:
#   default | client-example
#
VITE_SITE_THEME=showcase

# Structural home layout — section order + home “wow” weighting (see src/lib/layoutPresets.ts).
# Options: balanced | image-forward | text-forward | design-forward | story | commerce
#          | event-forward | data-forward | academy | community | launch
#          | minimal | local | nonprofit | lead-gen | trust
#          | pricing | newsroom | docs | changelog | app-shell
VITE_LAYOUT_PRESET=balanced
